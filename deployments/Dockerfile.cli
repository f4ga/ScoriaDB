FROM golang:1.25-alpine AS builder
RUN apk add --no-cache git ca-certificates
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o /scoria ./cmd/cli

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /scoria /usr/local/bin/scoria
ENTRYPOINT ["scoria"]